expression Users_fromGraph = ```
		let
		    // === Přihlašovací údaje ===
		    tenantId = "949c3b0c-e889-42e3-b5eb-d874e859d6e0",
		    clientId = "0a46a613-04e6-4cda-9abf-85d1ddc4460a",
		    tokenUrl = "https://login.microsoftonline.com/" & tenantId & "/oauth2/v2.0/token",
		    tokenBodyText = "grant_type=client_credentials" &
		                    "&client_id=" & clientId &
		                    "&client_secret=" & Uri.EscapeDataString(clientSecret) &
		                    "&scope=" & Uri.EscapeDataString("https://graph.microsoft.com/.default"),
		    tokenResponse = Json.Document(Web.Contents(tokenUrl, [
		        Content = Text.ToBinary(tokenBodyText),
		        Headers = [#"Content-Type"="application/x-www-form-urlencoded", Accept="application/json"]
		    ])),
		    access_token = tokenResponse[access_token],
		
		    // === Pomocná funkce pro stránkování ===
		    GetAllPages = (initialUrl as text) as list =>
		        let
		            getPage = (url, acc) =>
		                let
		                    response = Json.Document(Web.Contents(url, [
		                        Headers = [Authorization = "Bearer " & access_token, Accept = "application/json"]
		                    ])),
		                    data = response[value],
		                    next = try response[#"@odata.nextLink"] otherwise null,
		                    newAcc = acc & data
		                in
		                    if next = null then newAcc else @getPage(next, newAcc)
		        in
		            getPage(initialUrl, {}),
		
		    // === Získání všech uživatelů ===
		    allUsers = GetAllPages("https://graph.microsoft.com/v1.0/users?$select=displayName,id,onPremisesUserPrincipalName,onPremisesSamAccountName&$top=10"),
		    usersTable = Table.FromRecords(allUsers),
		
		    // === Získání licencí (subscribedSkus) ===
		    skusUrl = "https://graph.microsoft.com/v1.0/subscribedSkus",
		    skusResult = Json.Document(Web.Contents(skusUrl, [
		        Headers = [ Authorization="Bearer " & access_token, Accept="application/json" ]
		    ])),
		    skuList = skusResult[value],
		    skuMapTable = Table.FromRecords(List.Transform(skuList, each [
		        skuId = _[skuId],
		        skuPartNumber = _[skuPartNumber]
		    ])),
		
		    // === Funkce pro překlad skuId na skuPartNumber ===
		    GetSkuName = (id as text) as text =>
		        let found = Table.SelectRows(skuMapTable, each [skuId] = id)
		        in if Table.IsEmpty(found) then id else found{0}[skuPartNumber],
		
		    // === Funkce na získání licencí uživatele jako seznam záznamů ===
		    
		    GetUserLicensesTable = (userId as text) as table =>
		        let
		            baseUrl = "https://graph.microsoft.com/v1.0/",
		            relativePath = "users/" & userId & "/licenseDetails",
		            response = try Json.Document(Web.Contents(baseUrl, [
		                RelativePath = relativePath,
		                Headers = [
		                    Authorization = "Bearer " & access_token,
		                    Accept = "application/json"
		                ]
		            ])) otherwise [value = {}],
		            lis = response[value],
		            licenseRecords = List.Transform(lis, each [
		                skuId = _[skuId],
		                skuName = GetSkuName(_[skuId])
		            ]),
		            licenseTable = Table.FromRecords(licenseRecords)
		        in
		            licenseTable,
		
		    // === Pro každýho uživatele načteme licence a vytvoříme rozbalenou tabulku uživatelů s licencemi ===
		    UsersWithLicensesExpanded = Table.ExpandTableColumn(
		        Table.AddColumn(usersTable, "UserLicenses", each GetUserLicensesTable([id])),
		        "UserLicenses", {"skuName"}
		    ),
		    #"Added Custom" = Table.AddColumn(UsersWithLicensesExpanded, "UPN", each [onPremisesSamAccountName] & "@kompan.net"),
		    #"Uppercased Text" = Table.TransformColumns(#"Added Custom",{{"UPN", Text.Upper, type text}}),
		    #"Renamed Columns" = Table.RenameColumns(#"Uppercased Text",{{"displayName", "Display Name"}}),
		    #"Added Custom1" = Table.AddColumn(#"Renamed Columns", "Source", each "Graph API"),
		    #"Renamed Columns1" = Table.RenameColumns(#"Added Custom1",{{"Source", "DataSource"}, {"skuName", "Group Member"}}),
		    #"Replaced Value" = Table.ReplaceValue(#"Renamed Columns1","SPE_E5","Microsoft 365 E5",Replacer.ReplaceText,{"Group Member"}),
		    #"Replaced Value1" = Table.ReplaceValue(#"Replaced Value","OFFICESUBSCRIPTION","Microsoft 365 Apps for Enterprise",Replacer.ReplaceText,{"Group Member"}),
		    #"Removed Columns" = Table.RemoveColumns(#"Replaced Value1",{"id", "onPremisesUserPrincipalName"})
		in
		    #"Removed Columns"
		```
	lineageTag: b27c8a07-84b0-4c44-96b2-49515a6ec8bb
	queryGroup: old

