	/// Country inferred from Navision-related group membership.
	column NavisionCountry =
			
			SWITCH(
			    TRUE(),
			    LEFT(fact_UsersFromAD[Group Member], 10) = "NAV2016-AT", "Austria",
			    LEFT(fact_UsersFromAD[Group Member], 10) = "NAV2016-AU", "Australia",
			    LEFT(fact_UsersFromAD[Group Member], 10) = "NAV2016-BE", "Belgium",
			    LEFT(fact_UsersFromAD[Group Member], 11) = "NAV2016-BE1", "Belgium",
			    LEFT(fact_UsersFromAD[Group Member], 10) = "NAV2016-CH", "Switzerland",
			    LEFT(fact_UsersFromAD[Group Member], 10) = "NAV2016-CZ", "Czech Republic",
			    LEFT(fact_UsersFromAD[Group Member], 10) = "NAV2016-DE", "Germany",
			    LEFT(fact_UsersFromAD[Group Member], 10) = "NAV2016-DK", "Denmark",
			    LEFT(fact_UsersFromAD[Group Member], 10) = "NAV2016-ES", "Spain",
			    LEFT(fact_UsersFromAD[Group Member], 10) = "NAV2016-FI", "Finland",
			    LEFT(fact_UsersFromAD[Group Member], 10) = "NAV2016-FR", "France",
			    LEFT(fact_UsersFromAD[Group Member], 10) = "NAV2016-IE", "Ireland",
			    LEFT(fact_UsersFromAD[Group Member], 10) = "NAV2016-IT", "Italy",
			    LEFT(fact_UsersFromAD[Group Member], 10) = "NAV2016-NL", "Netherlands",
			    LEFT(fact_UsersFromAD[Group Member], 10) = "NAV2016-NO", "Norway",
			    LEFT(fact_UsersFromAD[Group Member], 10) = "NAV2016-SE", "Sweden",
			    LEFT(fact_UsersFromAD[Group Member], 10) = "NAV2016-SG", "Singapore",
			    LEFT(fact_UsersFromAD[Group Member], 10) = "NAV2016-UK", "United Kingdom",
			    LEFT(fact_UsersFromAD[Group Member], 11) = "NAV2016-UK1", "United Kingdom",
			    LEFT(fact_UsersFromAD[Group Member], 10) = "NAV2016-US", "United States",
			    fact_UsersFromAD[Group Member] // Default category if no match is found
			)
		lineageTag: dd9e2b7c-7237-4e4c-ab86-c844bd53361d
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Business-friendly license category derived from group membership.
	column Licences = ```
			
			IF
			(CONTAINSSTRING([Group Member], "SOLIDWORKSUsers"),
			    "Solid Works/Smarteam/PDM",
			   IF(
			        CONTAINSSTRING([Group Member], "NAV2016Users"),
			        "Navision",
			        IF(
			            [Group Member] = "AUTODESKUsers", 
			            "Autocad/3d Studio Max/etc.",
			            IF(
			                CONTAINSSTRING([Group Member], "QAD") || 
			                CONTAINSSTRING([Group Member], "Progress"),
			                "QAD/Progress",
			                IF(
			                    CONTAINSSTRING([Group Member], "D365Users - Online"),
			                    "CRM",
			                    IF(
			                        CONTAINSSTRING([Group Member], "Adobe") && NOT(CONTAINSSTRING([Group Member], "Creative")),
			                        "ADOBE Acr., Photo., Illu., InDesign (single app)",
			                        IF(
			                            CONTAINSSTRING([Group Member], "Adobe") && CONTAINSSTRING([Group Member], "Creative"),
			                            "ADOBE Create Cloud (all apps)",
			                            IF(
			                                [Group Member] = "TEMPLAFYUsers",
			                                "Omnidocs (Templafy)",
			                                IF(
			                                    [Group Member] = "VIS Performance",
			                                    "VIS Performance",
			                                    IF(
			                                        [Group Member] = "MediusUsers-KompanAS",
			                                        "Medius",
			                                        IF(
			                                            [Group Member] = "LMSUsers",
			                                            "LMS",
			                                            IF(
			                                                [Group Member] = "Slim4-PROD",
			                                                "Slimstock",
			                                                IF(
			                                                    [Group Member] = "BOXUsers",
			                                                    "BOX.com",
			                                                    IF(
			                                                        [Group Member] = "FUSIOUsers",
			                                                        "FUSIO",
			                                                        [Group Member]
			                                                    )
			                                                )
			                                            )    
			                                        )    
			                                    )    
			                                )    
			                            )    
			                        )
			                    )
			                )
			            )
			        )
			    )
			)
			```
		lineageTag: a22ee11e-8526-4fcb-9534-e2cd1b9317eb
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

