	partition Users_fromAD = m
		mode: import
		source =
				let
				    Source = ActiveDirectory.Domains("kompan.net"),
				    kompan.net = Source{[Domain="kompan.net"]}[#"Object Categories"],
				    user1 = kompan.net{[Category="user"]}[Objects],
				    #"Expanded top1" = Table.ExpandRecordColumn(user1, "top", {"memberOf", "whenChanged", "whenCreated"}, {"top.memberOf", "top.whenChanged", "top.whenCreated"}),
				    #"Expanded top.memberOf2" = Table.ExpandListColumn(#"Expanded top1", "top.memberOf"),
				    #"Expanded top.memberOf3" = Table.ExpandRecordColumn(#"Expanded top.memberOf2", "top.memberOf", {"cn", "displayName"}, {"top.memberOf.cn", "top.memberOf.displayName"}),
				    #"Filtered Rows" = Table.SelectRows(#"Expanded top.memberOf3", each ([top.memberOf.cn] <> null)),
				    #"Expanded user" = Table.ExpandRecordColumn(#"Filtered Rows", "user", {"givenName", "mail", "manager", "mobile", "userPrincipalName"}, {"user.givenName", "user.mail", "user.manager", "user.mobile", "user.userPrincipalName"}),
				    #"Expanded user.manager" = Table.ExpandRecordColumn(#"Expanded user", "user.manager", {"displayName"}, {"user.manager.displayName"}),
				    #"Expanded person" = Table.ExpandRecordColumn(#"Expanded user.manager", "person", {"sn"}, {"person.sn"}),
				    #"Expanded organizationalPerson" = Table.ExpandRecordColumn(#"Expanded person", "organizationalPerson", {"c", "co", "company", "countryCode", "department", "l", "postalCode", "streetAddress", "title"}, {"organizationalPerson.c", "organizationalPerson.co", "organizationalPerson.company", "organizationalPerson.countryCode", "organizationalPerson.department", "organizationalPerson.l", "organizationalPerson.postalCode", "organizationalPerson.streetAddress", "organizationalPerson.title"}),
				    #"Replaced Value1" = Table.ReplaceValue(#"Expanded organizationalPerson","Kompan A/S","KOMPAN A/S",Replacer.ReplaceValue,{"organizationalPerson.company"}),
				    #"Replaced Value2" = Table.ReplaceValue(#"Replaced Value1","Kompan Danmark A/S","KOMPAN Danmark A/S",Replacer.ReplaceText,{"organizationalPerson.company"}),
				    #"Expanded msExchCustomAttributes" = Table.ExpandRecordColumn(#"Replaced Value2", "msExchCustomAttributes", {"extensionAttribute2", "extensionAttribute3"}, {"msExchCustomAttributes.extensionAttribute2", "msExchCustomAttributes.extensionAttribute3"}),
				    #"Renamed Columns" = Table.RenameColumns(#"Expanded msExchCustomAttributes",{{"displayName", "DisplayName"}, {"user.givenName", "FirstName"}, {"user.mail", "Mail"}, {"user.manager.displayName", "Manager"}, {"user.mobile", "PhoneNumber"}, {"user.userPrincipalName", "UPN"}, {"organizationalPerson.c", "CountryCode"}, {"organizationalPerson.co", "Country"}, {"organizationalPerson.countryCode", "CountryCodeNumber"}, {"organizationalPerson.department", "Department"}, {"organizationalPerson.l", "City"}, {"organizationalPerson.postalCode", "PostalCode"}, {"organizationalPerson.streetAddress", "StreetAddress"}, {"organizationalPerson.title", "Title"}, {"person.sn", "LastName"}, {"top.memberOf.cn", "GroupMember"}, {"top.whenChanged", "WhenChangedDate"}, {"top.whenCreated", "WhenCreatedDate"}}),
				    #"Added Conditional Column1" = Table.AddColumn(#"Renamed Columns", "Country Code New", each if [organizationalPerson.company] = "KOMPAN Danmark A/S" then "DK1" else if [organizationalPerson.company] = "KOMPAN A/S (DK)" then "DK" else [CountryCode]),
				    #"Added Conditional Column2" = Table.AddColumn(#"Added Conditional Column1", "Country New", each if [CountryCode] = "DK1" then "Denmark" else if [organizationalPerson.company] = "Kompan Czech Republic s.r.o." then "Czech republic" else [Country]),
				    #"Reordered Columns1" = Table.ReorderColumns(#"Added Conditional Column2",{"DisplayName", "FirstName", "Mail", "Manager", "PhoneNumber", "UPN", "CountryCode", "Country", "Country New", "organizationalPerson.company", "CountryCodeNumber", "Department", "City", "PostalCode", "StreetAddress", "Title", "LastName", "GroupMember", "top.memberOf.displayName", "WhenChangedDate", "WhenCreatedDate", "posixAccount", "shadowAccount", "msExchOmaUser", "msExchBaseClass", "msExchCertificateInformation", "msExchIMRecipient", "msExchMultiMediaUser", "msExchMailStorage", "msExchCustomAttributes.extensionAttribute2", "msExchCustomAttributes.extensionAttribute3", "msDS-CloudExtensions", "securityPrincipal", "mailRecipient", "distinguishedName", "Country Code New"}),
				    #"Changed Type" = Table.TransformColumnTypes(#"Reordered Columns1",{{"WhenChangedDate", type date}, {"WhenCreatedDate", type date}}),
				    #"Reordered Columns" = Table.ReorderColumns(#"Changed Type",{"DisplayName", "FirstName", "Mail", "Manager", "PhoneNumber", "UPN", "CountryCode", "Country Code New", "Country", "organizationalPerson.company", "CountryCodeNumber", "Department", "City", "PostalCode", "StreetAddress", "Title", "LastName", "GroupMember", "top.memberOf.displayName", "WhenChangedDate", "WhenCreatedDate", "posixAccount", "shadowAccount", "msExchOmaUser", "msExchBaseClass", "msExchCertificateInformation", "msExchIMRecipient", "msExchMultiMediaUser", "msExchMailStorage", "msExchCustomAttributes.extensionAttribute2", "msExchCustomAttributes.extensionAttribute3", "msDS-CloudExtensions", "securityPrincipal", "mailRecipient", "distinguishedName"}),
				    #"Renamed Columns1" = Table.RenameColumns(#"Reordered Columns",{{"msExchCustomAttributes.extensionAttribute3", "ExtensionAttribute3"}, {"msExchCustomAttributes.extensionAttribute2", "ExtensionAttribute2"}}),
				    #"Removed Columns3" = Table.RemoveColumns(#"Renamed Columns1",{"CountryCode"}),
				    #"Renamed Columns4" = Table.RenameColumns(#"Removed Columns3",{{"Country Code New", "CountryCode"}}),
				    #"Removed Columns" = Table.RemoveColumns(#"Renamed Columns4",{"posixAccount", "shadowAccount", "msExchOmaUser", "msExchBaseClass", "msExchCertificateInformation", "msExchIMRecipient", "msExchMultiMediaUser", "msExchMailStorage", "securityPrincipal", "mailRecipient"}),
				    #"Renamed Columns2" = Table.RenameColumns(#"Removed Columns",{{"DisplayName", "DisplayName"}}),
				    #"Removed Columns1" = Table.RemoveColumns(#"Renamed Columns2",{"top.memberOf.displayName"}),
				    #"Filtered Rows1" = Table.SelectRows(#"Removed Columns1", each true),
				    #"Duplicated Column" = Table.DuplicateColumn(#"Filtered Rows1", "Mail", "Mail - Copy"),
				    #"Split Column by Delimiter" = Table.SplitColumn(#"Duplicated Column", "Mail - Copy", Splitter.SplitTextByEachDelimiter({"@"}, QuoteStyle.Csv, true), {"Mail - Copy.1", "Mail - Copy.2"}),
				    #"Changed Type1" = Table.TransformColumnTypes(#"Split Column by Delimiter",{{"Mail - Copy.1", type text}, {"Mail - Copy.2", type text}}),
				    #"Removed Columns2" = Table.RemoveColumns(#"Changed Type1",{"Mail - Copy.1"}),
				    #"Renamed Columns3" = Table.RenameColumns(#"Removed Columns2",{{"Mail - Copy.2", "Domain"}}),
				    #"Lowercased Text" = Table.TransformColumns(#"Renamed Columns3",{{"Domain", Text.Lower, type text}}),
				    #"Replaced Value" = Table.ReplaceValue(#"Lowercased Text",null,"No value",Replacer.ReplaceValue,{"Domain"}),
				    #"Added Conditional Column" = Table.AddColumn(#"Replaced Value", "Internal User", each if Text.Contains([Domain], "kompan") then "Yes" else "No"),
				    #"Renamed Columns5" = Table.RenameColumns(#"Added Conditional Column",{{"DisplayName", "Display Name"}, {"FirstName", "First Name"}, {"PhoneNumber", "Phone Number"}, {"GroupMember", "Group Member"}, {"LastName", "Last Name"}, {"StreetAddress", "Street Address"}, {"PostalCode", "Postal Code"}}),
				    #"Replaced Value3" = Table.TransformColumns(#"Renamed Columns5",{{"UPN", each if _ = null then null else if Text.EndsWith(Text.Lower(_), "@kompan.com") then Text.Start(_, Text.Length(_) - 4) & ".net" else _, type text}}),
				    #"Uppercased Text" = Table.TransformColumns(#"Replaced Value3",{{"UPN", Text.Upper, type text}}),
				    #"Added Custom" = Table.AddColumn(#"Uppercased Text", "User ID", each Text.BeforeDelimiter([UPN], "@")),
				    #"Reordered Columns2" = Table.ReorderColumns(#"Added Custom",{"User ID", "Display Name", "First Name", "Mail", "Manager", "Phone Number", "UPN", "CountryCode", "Country New", "Country", "organizationalPerson.company", "CountryCodeNumber", "Department", "City", "Postal Code", "Street Address", "Title", "Last Name", "Group Member", "WhenChangedDate", "WhenCreatedDate", "ExtensionAttribute2", "ExtensionAttribute3", "msDS-CloudExtensions", "distinguishedName", "Domain", "Internal User"}),
				    #"Added Custom1" = Table.AddColumn(#"Reordered Columns2", "DataSource", each "Active Directory")
				in
				    #"Added Custom1"

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

